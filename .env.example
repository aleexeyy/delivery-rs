HOST=0.0.0.0
APP_PORT=3000
RUN_MIGRATIONS=true

# PostgreSQL — these are read by both the postgres Docker image (to init the db) and the backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=delivery
POSTGRES_PORT=5432

# Use the Docker service name "postgres" as the hostname (not "localhost")
DATABASE_URL=postgres://postgres:postgres@postgres:5432/delivery

# Redis — use the Docker service name "redis" as the hostname
REDIS_URL=redis://redis:6379


RUST_LOG="delivery_rs=debug,tower_http=debug"
